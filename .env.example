# Discord
DISCORD_BOT_TOKEN=your_bot_token_here
# Chess alerts channel (example: CHESS_CHANNEL_ID from your server)
DISCORD_CHESS_CHANNEL_ID=1489792894754623538

# Groq — https://console.groq.com/
GROQ_API_KEY=your_groq_key_here

# Optional model (default: openai/gpt-oss-120b)
# GROQ_MODEL=openai/gpt-oss-120b

# Optional Lichess overrides
# LICHESS_API_BASE=https://lichess.org/api
# LICHESS_SITE_BASE=https://lichess.org

# Optional OAuth (not required for search/follow/monitor)
# LICHESS_API_TOKEN=

# Polling (seconds)
# POLL_INTERVAL_SECONDS=10
# REMINDER_MINUTES_BEFORE=60
# ROUND_CHECK_INTERVAL_SECONDS=120
