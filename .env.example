# Required — Discord
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_CHESS_CHANNEL_ID=123456789012345678

# Required — Groq (https://console.groq.com/)
GROQ_API_KEY=your_groq_key_here

# Optional — model id (default: openai/gpt-oss-120b)
# GROQ_MODEL=openai/gpt-oss-120b

# Optional — which Lichess broadcast the bot watches and posts updates for (8-char ID + public URL)
# MONITORED_BROADCAST_ID=OqKQ3sJH
# MONITORED_BROADCAST_URL=https://lichess.org/broadcast/fide-candidates-2026--combined-open--women/OqKQ3sJH

# Optional — Lichess API overrides
# LICHESS_API_BASE=https://lichess.org/api
# LICHESS_SITE_BASE=https://lichess.org

# Optional — OAuth token with study:read for /lichess my_rounds and richer /lichess by_user
# LICHESS_API_TOKEN=

# Optional — polling (seconds)
# POLL_INTERVAL_SECONDS=10
# REMINDER_MINUTES_BEFORE=60
# ROUND_CHECK_INTERVAL_SECONDS=120
